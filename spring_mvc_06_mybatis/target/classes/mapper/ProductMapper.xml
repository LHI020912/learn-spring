<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
 <!-- namespace: 이 mapper가 구현할 인터페이스 정보(패키지명, 인터페이스명)
 	  인터페이스 구현 클래스와 같은 의미 -> 인터페이스 내 모든 추상메소드가 표현되어야 함
 -->
 <mapper namespace="com.spring_mvc.batis.model.IProductDAO">
 	<!-- 특정테이블 컬럼과 타입의 클래스 필드를 1:1로 매핑 -->
 	<resultMap id="prdResult" type="com.spring_mvc.batis.vo.ProductVO">
 		<result property="prdNo" column="prdNo"/>
 		<result property="prdName" column="prdName"/>
 		<result property="prdPrice" column="prdPrice"/>
 		<result property="prdCompany" column="prdCompany"/>
 		<result property="prdStock" column="prdStock"/>
 		<result property="prdDate" column="prdDate"/>
 	</resultMap>
 	<!-- 
 		<쿼리태그 id="메소드명" [resultMap=""/resoultType=""/parameterType=""/statementType=""]>
 			실행 쿼리 문장
 		</쿼리태그>
 		반환결과 :resultMap=""/ resultType="" -> 집합타입의 의미가 아니고 레코드 타입을 의미
 		메소드 파라미터: parameterType=""
 		statement 객체 타입: statementType="" (생략-> preapred 사용)
 	 -->
 
 	<!-- 전체 상품 조회 : id속성 value mapper가 구현하는 dao 인터페이스의 추상메소드와 이름이 같아야함 -->
 	<!-- 조회: select ⇒ 반환값 있음 resultType/resultMap(mapper가 구성함)필수 -->
 	<!-- 
 	<select id="listAllProduct" resultMap="prdResult">
 		SELECT * FROM product ORDER BY prdNo
 	</select>
	  -->
	  
	<!-- resultType사용: 클래스 필드명과 테이블 컬럼명이 동일해야 함 -->
  	<select id="listAllProduct" resultType="com.spring_mvc.batis.vo.ProductVO">
 		SELECT * FROM product ORDER BY prdNo
 	</select>
 	
 	<!-- 상품 정보 등록 : void insertProduct(ProductVO prdVo); -->
 	<!-- parameterType: 실제 전달되는 data type 전달
 		 parameter활용: 홀더문자 #{ } :preparedStatement -> / ${ } statement 사용 -->
 	<insert id="insertProduct" parameterType="com.spring_mvc.batis.vo.ProductVO">
 		INSERT INTO product(prdNo, prdName, prdPrice, prdCompany, prdStock, prdDate)
 		VALUES (#{prdNo}, #{prdName}, #{prdPrice},#{prdCompany},#{prdStock},#{prdDate})
 	</insert>
 	
 	<!-- 상품 상세 정보 : ProductVO detailViewProduct(String prdNo);
 		 parameterType : 개발자 생성 객체 : 패키지 명부터 클래스 명까지
 		 			   : 기본객체 ->객체명만 소문자로 -->
 	<select id="detailViewProduct" parameterType="string" resultType="com.spring_mvc.batis.vo.ProductVO">
 		SELECT * FROM PRODUCT WHERE PRDNO= #{prdNo}
 	</select>
 	
 	<!-- 상품정보 수정 : void updateProduct(ProductVO prdVo) -->
 	<update id="updateProduct" parameterType="com.spring_mvc.batis.vo.ProductVO">
 		UPDATE product SET prdName= #{prdName},prdPrice=#{prdPrice},prdCompany=#{prdCompany},
 						   prdStock=#{prdStock},prdDate =#{prdDate}
 		WHERE prdNo=#{prdNo}
 	</update>
 	
 	<!-- 상품정보 삭제 : void deleteProduct(String prdNo) -->
 	<delete id="deleteProduct" parameterType="string">
 		DELETE FROM product WHERE prdNo=#{prdNo}
 	</delete>
 	
 	<!-- 상품 번호 중복확인 : String prdNoCheck(String prdNo) -->
 	<select id="prdNoCheck" resultType="string" parameterType="string">
 		SELECT prdNo FROM product WHERE prdNo=#{prdNo}
 	</select>
 	
 	<!-- 상품 검색 : ArrayList<ProductVO>productSearch(HashMap<String,Object>map) -->
 	<!-- 파라미터 hashmap에 저장된 key : type, keyword -->
 	<select id="productSearch" resultMap="prdResult" parameterType="hashmap">
 		SELECT * FROM product WHERE
 			<choose>
 				<when test="type != null and type.equals('prdName')">
 					prdName LIKE '%'||#{keyword}||'%'
 				</when>
 				<when test="type != null and type.equals('prdCompany')">
 					prdCompany LIKE '%'||#{keyword}||'%'
 				</when>
 			</choose>
 	</select>
 </mapper>