package com.spiring_aop.annotation;

public class Circle {
	private int cle;

	public int getCle() {
		return cle;
	}

	public void setCle(int cle) {
		this.cle = cle;
	}
	
	public void showCleResult() {
		System.out.println("원의 넓이: "+(cle*cle*3.14));
		System.out.println("원의 둘레: "+(cle*2*3.14));
	}
}
